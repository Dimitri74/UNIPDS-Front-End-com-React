{
  "info": {
    "name": "Tasks CRUD App",
    "description": "Collection completa para a API do react-tasks-crud-app.\n\nAntes de usar:\n1. Defina a variável `baseUrl` com a URL do backend (ex: http://localhost:3001)\n2. Execute **Register** ou **Login** — o token JWT é salvo automaticamente em `authToken`.\n3. As demais requisições já usam `authToken` no cabeçalho Authorization.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string",
      "description": "URL base do backend (sem barra final)"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string",
      "description": "JWT preenchido automaticamente após Login ou Register"
    },
    {
      "key": "taskId",
      "value": "",
      "type": "string",
      "description": "ID de uma tarefa — preencha após listar as tasks"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Rotas de autenticação",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('authToken', res.token);",
                  "    pm.test('Token salvo com sucesso', () => pm.expect(res.token).to.be.a('string'));",
                  "} else {",
                  "    pm.test('Registro falhou: ' + (res.message || 'sem mensagem'), () => pm.expect.fail());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"Marcus\",\n  \"email\": \"marcus@example.com\",\n  \"password\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Cria um novo usuário. Salva o JWT retornado em `authToken`."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('authToken', res.token);",
                  "    pm.test('Token salvo com sucesso', () => pm.expect(res.token).to.be.a('string'));",
                  "} else {",
                  "    pm.test('Login falhou: ' + (res.message || 'sem mensagem'), () => pm.expect.fail());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"marcus@example.com\",\n  \"password\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Autentica o usuário. Salva o JWT retornado em `authToken`."
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "description": "CRUD de tarefas — todas as rotas requerem o JWT em Authorization.",
      "item": [
        {
          "name": "List Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "if (res.tasks && res.tasks.length > 0) {",
                  "    pm.collectionVariables.set('taskId', res.tasks[0]._id);",
                  "    pm.test('taskId salvo: ' + res.tasks[0]._id, () => pm.expect(res.tasks[0]._id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            },
            "description": "Retorna todas as tarefas do usuário autenticado. Salva o `_id` da primeira tarefa em `taskId`."
          }
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 ou 200', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Minha nova tarefa\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            },
            "description": "Cria uma nova tarefa para o usuário autenticado."
          }
        },
        {
          "name": "Complete Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}/complete",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}", "complete"]
            },
            "description": "Marca a tarefa `taskId` como concluída."
          }
        },
        {
          "name": "Delete Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            },
            "description": "Remove a tarefa `taskId`."
          }
        }
      ]
    }
  ]
}
